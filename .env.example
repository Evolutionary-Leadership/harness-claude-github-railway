# Railway environment variables
# These are automatically set by Railway, so you don't need to configure them manually.
# This file documents what's available for local development.

# App
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
# In Railway, this is wired automatically via ${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# Object Storage (S3-compatible bucket)
# In Railway, these are set automatically by the bucket plugin
AWS_S3_BUCKET_NAME=my-bucket
AWS_ENDPOINT_URL=https://s3.us-east-1.amazonaws.com
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_DEFAULT_REGION=auto
